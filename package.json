{
  "name": "voyage",
  "private": true,
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd apps/web build",
    "check": "bun run format:check && bun run typecheck && bun run test && bun run build",
    "deploy": "bun run --cwd apps/web deploy",
    "dev": "bun run --cwd apps/web dev",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "preview": "bun run --cwd apps/web preview",
    "test": "bun run --cwd apps/web test",
    "typecheck": "bun run --cwd apps/web typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4"
  }
}
